# Local-only environment variables (do not commit real values)

# Firebase CLI token for App Distribution (generated via `firebase login:ci`)
FIREBASE_TOKEN=

# Optional: GitHub token for `gh` (lets deploy scripts check CI without relying on C:\Users\...\gh config)
# GH_TOKEN=... or GITHUB_TOKEN=...
GH_TOKEN=

# Optional deploy toggles
# DEPLOY_SKIP_CI=1
# DEPLOY_SKIP_FIREBASE=1

# RuStore deploy
# RUSTORE_PUBLIC_TOKEN=
# RUSTORE_PACKAGE_NAME=com.runterra.runterra
# RUSTORE_ARTIFACT_TYPE=apk
# RUSTORE_APP_TYPE=MAIN
# RUSTORE_PUBLISH_TYPE=MANUAL
# RUSTORE_MIN_ANDROID_VERSION=8
# RUSTORE_PRIORITY_UPDATE=0
# RUSTORE_MODER_INFO=
# RUSTORE_SKIP_COMMIT=0
# RUSTORE_SKIP_TAG=0

# Android release signing for RuStore / production builds
# ANDROID_KEYSTORE_PATH=D:\myprojects\Runterra\.secrets\android\upload-keystore.jks
# ANDROID_KEYSTORE_PASSWORD=
# ANDROID_KEY_ALIAS=
# ANDROID_KEY_PASSWORD=

# Workaround for restricted environments where global git config is inaccessible:
# GIT_CONFIG_GLOBAL=NUL
