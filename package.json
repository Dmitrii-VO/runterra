{
  "name": "runterra",
  "private": true,
  "description": "Runterra monorepo",
  "scripts": {
    "ai:check": "powershell -ExecutionPolicy Bypass -File scripts/ai-check.ps1",
    "ai:auto": "powershell -ExecutionPolicy Bypass -File scripts/ai-auto.ps1 --%",
    "ai:auto:chat": "powershell -ExecutionPolicy Bypass -File scripts/ai-auto-chat.ps1 --%",
    "ai:codex": "powershell -ExecutionPolicy Bypass -File scripts/ai-assistant.ps1 codex",
    "ai:claude": "powershell -ExecutionPolicy Bypass -File scripts/ai-assistant.ps1 claude",
    "ai:agent": "powershell -ExecutionPolicy Bypass -File scripts/ai-assistant.ps1 agent",
    "ctx:start": "powershell -ExecutionPolicy Bypass -File scripts/context-loop.ps1 start --%",
    "ctx:plan": "powershell -ExecutionPolicy Bypass -File scripts/context-loop.ps1 plan",
    "ctx:checkpoint": "powershell -ExecutionPolicy Bypass -File scripts/context-loop.ps1 checkpoint",
    "ctx:restore": "powershell -ExecutionPolicy Bypass -File scripts/context-loop.ps1 restore",
    "ctx:prune": "powershell -ExecutionPolicy Bypass -File scripts/context-loop.ps1 prune",
    "ctx:done": "powershell -ExecutionPolicy Bypass -File scripts/context-loop.ps1 done",
    "deploy": "powershell -ExecutionPolicy Bypass -File scripts/deploy-all.ps1",
    "deploy:mobile": "powershell -ExecutionPolicy Bypass -File scripts/deploy-mobile.ps1",
    "deploy:backend": "powershell -ExecutionPolicy Bypass -File scripts/deploy-backend.ps1"
  }
}
